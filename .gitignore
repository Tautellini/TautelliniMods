# logs and dumps copied in for analysis
*.log
*ObjectDump*.txt
*.usmap
*.dmp

# editor noise
.vs/
*.swp
Thumbs.db

# local LuaJIT test runtime (install per CONTRIBUTING.md, never committed)
tools/luajit/

# python tooling cache
__pycache__/

# bundled UE4SS for release builds (populate from a tested install, never committed)
tools/ue4ss/

# release build output (regenerated by the tools/*_build_release.ps1 scripts)
G1R/*/release/build/

# LockpickSettings release/ is fully local: build output plus archived zips and
# per-version notes. Distribution is via GitHub Releases, not the repo. The one
# build input that used to live here (the bundled readme) moved to
# G1R/LockpickSettings/bundled-readme.txt, which stays tracked.
G1R/LockpickSettings/release/

# SharedModMenu release/ is likewise local (manual zip + standalone modmenu.lua + per-version
# notes); distribution is via GitHub Releases, not the repo.
G1R/SharedModMenu/release/

# crash dumps / logs users send for triage: kept locally, never committed
G1R/LockpickSettings/user-reported-logs/

# Photoshop source art is large; keep the exported PNG/WEBP in the repo, not the .psd
*.psd

# deploy_env.ps1 safety backups of the game's UE4SS-settings.ini / mods.txt / binary
tools/.env-backup/

# generated, local-only, and runtime noise (not committed)
*.preview.html
tools/sim_variants.py
.claude/scheduled_tasks.lock
