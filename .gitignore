# logs and dumps copied in for analysis
*.log
*ObjectDump*.txt
*.usmap
*.dmp

# editor noise
.vs/
*.swp
Thumbs.db

# local Lua 5.4 test runtime: UE4SS runs PUC Lua 5.4, so tests run against it (build per
# CONTRIBUTING.md, never committed). tools/lua54/ is the built lua.exe, tools/lua-5.4.7/ the
# source. The old LuaJIT runtime is no longer used by the runners but stays ignored if present.
tools/lua54/
tools/lua-5.4.7/
tools/lua-5.4.7.tar.gz
tools/luajit/

# python tooling cache
__pycache__/

# bundled UE4SS for release builds (populate from a tested install, never committed)
tools/ue4ss/

# release build output (regenerated by the tools/*_build_release.ps1 scripts)
G1R/*/release/build/

# LockpickSettings release/ is fully local: build output plus archived zips and
# per-version notes. Distribution is via GitHub Releases, not the repo. The one
# build input that used to live here (the bundled readme) moved to
# G1R/LockpickSettings/bundled-readme.txt, which stays tracked.
G1R/LockpickSettings/release/

# SharedModMenu release/ is likewise local (manual zip + standalone modmenu.lua + per-version
# notes); distribution is via GitHub Releases, not the repo.
G1R/SharedModMenu/release/

# FastTravelAnywhere release/ is likewise local; distribution is via GitHub Releases, not the repo.
G1R/FastTravelAnywhere/release/

# crash dumps / logs users send for triage: kept locally, never committed
G1R/LockpickSettings/user-reported-logs/

# Photoshop source art is large; keep the exported PNG/WEBP in the repo, not the .psd
*.psd

# planning docs are working notes, obsolete once the work ships; kept local, never pushed
plans/

# nexus-page/ folders hold only the images shown on the NexusMods page; the BBCode body is a
# local working copy pasted into Nexus by hand, not a repo artifact
*.bbcode

# deploy_env.ps1 safety backups of the game's UE4SS-settings.ini / mods.txt / binary
tools/.env-backup/

# generated, local-only, and runtime noise (not committed)
*.preview.html
tools/sim_variants.py
.claude/scheduled_tasks.lock

# investigation scratch: ad-hoc skeptic/policy comparison scripts and their text dumps from the
# lockpick work. Kept local, never committed.
tools/_*

# third-party reference mod kept locally for technique study, never shipped or tracked
G1R/TautelliniConsole/reference/

# offline UFunction dump (large PDF/zip) used to find the map projection API; kept local
G1R/reference/Gothic 1 Remake Hook Candidate Collection/

# UE4SS docs source PDF; kept local. The parsed, committed copy is
# G1R/reference/UE4SS-Documentation.md (regenerate via tools/parse_ue4ss_docs.py).
tools/UE4SS Documentation.pdf
